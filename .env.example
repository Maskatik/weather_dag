# Airflow user ID
AIRFLOW_UID=1000

# Open-Meteo API key (get one at https://open-meteo.com/)
API_KEY=your_api_key_here

# Database credentials
DB_HOST=db
DB_PORT=5432
DB_NAME=db
DB_USER=admin
DB_PASSWORD=changeme

# Airflow PostgreSQL
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=changeme
AIRFLOW_DB_NAME=airflow

# Airflow Fernet key (generate with: openssl rand -base64 32)
AIRFLOW__CORE__FERNET_KEY=

# Airflow secret key (generate with: openssl rand -base64 32)
AIRFLOW__API__SECRET_KEY=

# Airflow JWT secret (generate with: openssl rand -base64 32)
AIRFLOW__API_AUTH__JWT_SECRET=
